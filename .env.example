# AI Provider API Keys (configure one or more)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here
GEMINI_API_KEY=your-gemini-key-here
MISTRAL_API_KEY=your-mistral-key-here
LLAMA_API_KEY=your-llama-key-here
XAI_API_KEY=your-xai-key-here
PERPLEXITY_API_KEY=your-perplexity-key-here

# AI model (optional — defaults to claude-sonnet-4-20250514)
# Supports: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-20250414,
#           gpt-4o, gpt-4o-mini, o3, o3-mini, o4-mini,
#           gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash,
#           mistral-large-latest, mistral-medium-latest, mistral-small-latest,
#           Llama-4-Maverick-17B-128E-Instruct-FP8, Llama-4-Scout-17B-16E-Instruct, Llama-3.3-70B-Instruct,
#           grok-3, grok-3-fast, grok-3-mini, grok-3-mini-fast,
#           sonar-pro, sonar, sonar-reasoning-pro, sonar-reasoning
AI_MODEL=claude-sonnet-4-20250514

# Image generation provider: openai or gemini
IMAGE_PROVIDER=openai
